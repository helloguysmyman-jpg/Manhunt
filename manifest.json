<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="theme-color" content="#05080d"/>
  <title>MANHUNT</title>
  <link rel="manifest" href="manifest.json"/>
  <link rel="apple-touch-icon" href="icons/icon-192.png"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>
<div id="app">

  <!-- ═══════════════════════ AUTH ════════════════════════════════════ -->
  <div id="screen-auth" class="screen">
    <div class="spacer"></div>
    <div style="text-align:center;margin-bottom:36px">
      <div class="logo-wrap">
        <div class="logo-ring"></div><div class="logo-ring"></div><div class="logo-ring"></div>
        <span style="font-size:60px;line-height:1;position:relative">🎯</span>
      </div>
      <div class="title-xl" style="margin-top:10px">MAN<br/><span style="color:var(--red)">HUNT</span></div>
    </div>

    <div id="auth-tabs">
      <button id="tab-login"  class="auth-tab active" onclick="switchAuthTab('login')">Sign In</button>
      <button id="tab-signup" class="auth-tab"        onclick="switchAuthTab('signup')">Create Account</button>
    </div>

    <!-- Login -->
    <div id="auth-login-form">
      <div class="card">
        <label class="input-label">Email</label>
        <input type="email" id="login-email" placeholder="you@example.com" autocomplete="email"/>
        <label class="input-label gap">Password</label>
        <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password"/>
        <div id="login-error" class="mono gap" style="font-size:11px;color:var(--red)"></div>
      </div>
      <button class="btn btn-fill gap-lg" onclick="doLogin()">Sign In →</button>
    </div>

    <!-- Sign Up -->
    <div id="auth-signup-form" style="display:none">
      <div class="card">
        <label class="input-label">Display Name</label>
        <input type="text" id="signup-name" placeholder="Your name in game" autocomplete="nickname"/>
        <label class="input-label gap">Email</label>
        <input type="email" id="signup-email" placeholder="you@example.com" autocomplete="email"/>
        <label class="input-label gap">Password</label>
        <input type="password" id="signup-pass" placeholder="6+ characters" autocomplete="new-password"/>
        <div id="signup-error" class="mono gap" style="font-size:11px;color:var(--red)"></div>
      </div>
      <button class="btn btn-fill gap-lg" onclick="doSignup()">Create Account →</button>
    </div>
    <div class="spacer"></div>
  </div>

  <!-- ═══════════════════════ HOME ════════════════════════════════════ -->
  <div id="screen-home" class="screen">
    <div class="row" style="justify-content:space-between;margin-bottom:8px">
      <div class="mono muted" style="font-size:11px">Signed in as <span id="home-name" style="color:var(--green)"></span></div>
      <button class="btn btn-sm btn-muted" style="width:auto;padding:6px 12px" onclick="doLogout()">Sign Out</button>
    </div>

    <div class="spacer"></div>
    <div style="margin-bottom:44px">
      <div class="logo-wrap">
        <div class="logo-ring"></div><div class="logo-ring"></div><div class="logo-ring"></div>
        <span style="font-size:64px;line-height:1;position:relative">🎯</span>
      </div>
      <div class="title-xl" style="margin-top:12px">MAN<br/><span style="color:var(--red)">HUNT</span></div>
      <div class="mono gap" style="font-size:10px;letter-spacing:4px;color:var(--red)">REAL-WORLD GPS TRACKING GAME</div>
    </div>

    <div style="display:flex;flex-direction:column;gap:10px">
      <button class="btn btn-fill" onclick="goCreate()">Create Game</button>
      <button class="btn"          onclick="goJoin()">Join Game</button>
    </div>

    <div class="card gap-lg mono" style="font-size:11px;color:var(--muted);line-height:2.3">
      <div><span style="color:var(--green)">📍 Real GPS</span> — grant location access</div>
      <div><span style="color:var(--yellow)">📡 3-min pings</span> — hunters get snapshots only</div>
      <div><span style="color:var(--blue)">🏃 10 min escape</span> before hunt begins</div>
      <div><span style="color:var(--red)">⚡ PWA</span> — add to Home Screen for best experience</div>
    </div>
    <div class="spacer"></div>
  </div>

  <!-- ══════════════════════ CREATE ═══════════════════════════════════ -->
  <div id="screen-create" class="screen">
    <button class="btn btn-sm" style="width:auto;padding:8px 16px;margin-bottom:16px" onclick="showScreen('home')">← Back</button>
    <div class="title-lg">New Game</div>

    <div class="card gap">
      <span class="label label-yellow">Game Code — share this</span>
      <div id="create-code" class="mono" style="font-size:44px;font-weight:900;letter-spacing:8px;color:var(--yellow);text-shadow:0 0 20px rgba(255,209,102,.4)"></div>
      <div class="mono muted gap" style="font-size:11px">Players enter this to join — roles assigned automatically</div>
    </div>

    <div class="card gap">
      <span class="label label-red">Number of Hunters</span>
      <div class="row" style="justify-content:center;gap:20px">
        <button class="btn btn-icon btn-red" onclick="changeHunters(-1)">−</button>
        <div id="hunter-count" style="font-size:48px;font-weight:900;color:var(--red);width:60px;text-align:center">1</div>
        <button class="btn btn-icon btn-red" onclick="changeHunters(1)">+</button>
      </div>
      <div class="mono muted" style="font-size:11px;text-align:center;margin-top:4px">
        Roles randomly assigned to all players at start
      </div>
    </div>

    <div class="card gap">
      <span class="label">Timings</span>
      <div class="mono muted" style="font-size:11px;line-height:2.2">
        Escape window: <span style="color:var(--green)">10:00</span><br/>
        Ping interval: <span style="color:var(--yellow)">3:00</span><br/>
        Catch radius: <span style="color:var(--red)">8 metres</span>
      </div>
    </div>

    <div class="spacer"></div>
    <button class="btn btn-fill gap-lg" onclick="createAndLobby()">Create → Lobby</button>
  </div>

  <!-- ══════════════════════ JOIN ══════════════════════════════════════ -->
  <div id="screen-join" class="screen">
    <button class="btn btn-sm" style="width:auto;padding:8px 16px;margin-bottom:16px" onclick="showScreen('home')">← Back</button>
    <div class="title-lg">Join Game</div>

    <div class="card gap">
      <span class="label">Game Code</span>
      <input type="text" id="join-input" class="code-input" placeholder="A1B2C3"
        maxlength="6" autocomplete="off" autocorrect="off" spellcheck="false"
        oninput="this.value=this.value.toUpperCase();onJoinCodeInput()"/>
    </div>

    <!-- NO role selection here — host assigns roles -->
    <div class="card gap card-green">
      <span class="label">Role Assignment</span>
      <div class="mono muted" style="font-size:11px;line-height:2">
        Roles are randomly assigned by the host when the game starts.<br/>
        You'll see your role — Hunter or Runner — once play begins.
      </div>
    </div>

    <div class="spacer"></div>
    <button id="join-btn" class="btn btn-fill gap-lg" onclick="joinAndLobby()" disabled>Join →</button>
  </div>

  <!-- ═══════════════════════ LOBBY ════════════════════════════════════ -->
  <div id="screen-lobby" class="screen">
    <div class="row" style="justify-content:space-between;align-items:flex-start">
      <div>
        <div class="mono muted" style="font-size:9px;letter-spacing:3px">LOBBY</div>
        <div id="lobby-code" class="mono" style="font-size:40px;font-weight:900;color:var(--yellow);letter-spacing:5px"></div>
      </div>
      <div style="text-align:right">
        <div id="gps-status" class="mono" style="font-size:11px;color:var(--yellow)">
          <span class="spin">⊙</span> Acquiring GPS…
        </div>
      </div>
    </div>

    <div class="card gap">
      <span class="label">Players</span>
      <div id="player-list"></div>
    </div>

    <!-- Waiting for start (non-host) -->
    <div id="lobby-waiting-msg" class="card gap card-green" style="display:none;text-align:center;padding:22px">
      <div style="font-size:26px;margin-bottom:8px" class="pulse">⏳</div>
      <div class="mono muted" style="font-size:11px;letter-spacing:2px">WAITING FOR HOST TO START</div>
      <div class="mono gap" style="font-size:10px;color:#1a2a1a">
        Invite others with code <span style="color:var(--yellow)" id="waiting-code"></span>
      </div>
    </div>

    <div class="spacer"></div>

    <!-- Host only -->
    <button id="lobby-start-btn" class="btn btn-fill gap-lg" onclick="hostStartGame()" style="display:none">
      Start Game →
    </button>
  </div>

  <!-- ════════════════════════ GAME ════════════════════════════════════ -->
  <div id="screen-game" class="screen">

    <!-- HUD -->
    <div id="hud">
      <div class="hud-timer">
        <div id="phase-lbl" class="phase-lbl" style="color:var(--green)">ESCAPE PHASE</div>
        <div id="timer-val" class="time-val"  style="color:var(--green)">10:00</div>
      </div>
      <div id="role-chip" class="hud-chip">
        <div id="chip-icon"  class="chip-icon">🏃</div>
        <div id="chip-label" class="chip-label">RUNNER</div>
      </div>
      <div id="ping-chip" class="hud-chip" style="display:none">
        <div id="ping-val"  class="chip-val" style="color:var(--red)">3:00</div>
        <div class="chip-label" style="color:var(--muted)">NEXT PING</div>
      </div>
    </div>

    <!-- Map -->
    <div id="map-wrap">
      <div id="map"></div>

      <!-- Acquiring GPS -->
      <div id="ov-acquiring" class="map-overlay">
        <div class="spin" style="font-size:38px;color:var(--green)">⊙</div>
        <div class="mono gap" style="font-size:12px;letter-spacing:3px;color:var(--green)">ACQUIRING GPS…</div>
        <div class="mono gap" style="font-size:10px;color:var(--muted);max-width:220px;text-align:center;line-height:1.9">
          Allow location access when prompted.<br/>
          For best accuracy, go outdoors.
        </div>
      </div>

      <!-- Phase overlay -->
      <div id="ov-phase" class="map-overlay" style="display:none">
        <div id="phase-box" class="phase-box">
          <div id="pb-icon"  class="pb-icon"></div>
          <div id="pb-title" class="pb-title"></div>
          <div id="pb-sub"   class="pb-sub"></div>
        </div>
      </div>

      <!-- Info panel -->
      <div id="ov-info" class="map-overlay" style="display:none">
        <div id="info-label"   class="label" style="font-size:9px;margin-bottom:5px">INFO</div>
        <div id="info-content" class="mono"  style="font-size:11px;line-height:1.9"></div>
        <div id="info-sub"     class="mono muted" style="font-size:9px;margin-top:5px;line-height:1.6"></div>
      </div>

      <!-- Caught overlay -->
      <div id="ov-caught" class="map-overlay" style="display:none">
        <div style="font-size:52px">🔴</div>
        <div class="mono" style="font-size:22px;font-weight:900;color:var(--red);letter-spacing:3px;margin-top:10px">
          YOU'VE BEEN CAUGHT
        </div>
        <div class="mono muted gap" style="font-size:11px">Game continues for remaining runners</div>
      </div>
    </div>

    <!-- Bottom -->
    <div id="bottom-panel">
      <div id="event-log"></div>
      <button class="btn btn-red btn-sm" onclick="endGame()">End Game</button>
    </div>

  </div>

  <!-- ════════════════════ LEADERBOARD ═════════════════════════════════ -->
  <div id="screen-leaderboard" class="screen">
    <div style="text-align:center;padding:10px 0 20px">
      <div style="font-size:52px">🏁</div>
      <div class="title-lg" style="margin-top:8px">Game Over</div>
      <div id="lb-code" class="mono muted" style="font-size:10px;letter-spacing:3px;margin-top:6px"></div>
    </div>

    <div id="lb-role" class="card"></div>

    <div class="card gap">
      <span class="label">Your Stats</span>
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-lbl">DISTANCE</div>
          <div id="stat-dist"  class="stat-val" style="color:var(--green)">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-lbl">TIME IN HUNT</div>
          <div id="stat-time"  class="stat-val" style="color:var(--blue)">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-lbl">AVG SPEED</div>
          <div id="stat-speed" class="stat-val" style="color:var(--yellow)">—</div>
        </div>
        <div class="stat-box">
          <div class="stat-lbl">PINGS FIRED</div>
          <div id="stat-pings" class="stat-val" style="color:var(--red)">—</div>
        </div>
      </div>
    </div>

    <div class="card card-yellow gap">
      <span class="label label-yellow">📊 Full Leaderboard</span>
      <div class="mono muted" style="font-size:11px;line-height:2">
        With Firebase connected, every player's distance covered,
        closest approach without being caught, speed profile, and
        survival time all sync here for everyone in the session.
      </div>
    </div>

    <div class="card gap">
      <div id="stat-samples" class="mono muted" style="font-size:11px"></div>
    </div>

    <div class="spacer"></div>
    <button class="btn btn-fill gap-lg" onclick="newGame()">New Game</button>
  </div>

</div><!-- #app -->

<!-- Toast -->
<div id="toast" class="mono"></div>

<!-- Firebase (add your SDK scripts here once you have a project) -->
<!-- <script src="https://www.gstatic.com/firebasejs/9.x.x/firebase-app-compat.js"></script>   -->
<!-- <script src="https://www.gstatic.com/firebasejs/9.x.x/firebase-auth-compat.js"></script>  -->
<!-- <script src="https://www.gstatic.com/firebasejs/9.x.x/firebase-database-compat.js"></script> -->

<!-- Leaflet -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<!-- App -->
<script src="app.js"></script>
</body>
</html>
